<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.3.0/model-viewer.min.js"></script>
</head>
<body>
    <div class="fullpg">
        <div class="section1">
            <h1 class="heading">LOGIN</h1>
            <form action="/login" method="post" class="form">
                <input type="email" placeholder="Email Address" name="email" class="input" required>
                <input type="password" placeholder="Password" name="password" class="input" id="pwd" required>
                <button type="submit" class="button">Submit</button>
                <p class="warningText">Don't have an account <br> <a href="/register" class="warningText">Register Now!</a></p>
            </form>    
        </div>
    </div>
</body>
</html>