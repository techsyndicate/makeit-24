<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title></title>
    <style>
        @font-face {
            font-family: Sentex;
            src: url(/fonts/Sentex/Sentex-Regular.ttf);
        }
        @font-face {
            font-family: BlenderPro;
            src: url(/fonts/BlenderPro/BlenderPro-Medium.ttf);
        }
        body {
            margin: 0px;
            overflow-x: hidden;
            color: white;
            font-family: Sentex;
        }
        video {
            height: 100vh;
            width: 100vw;
            object-fit: cover;
            position: fixed;
            top: 0;
            left: 0;
            z-index: -2;
        }
        .overlayBg {
            width: 100vw;
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            object-fit: cover;
        }
        .navbar {
            position: absolute;
            right: 1vw;
            top: 1vw;
            display: flex;
            margin: 1vw;
            border: 0.13vw solid #00ffff;
            font-family: BlenderPro;
            clip-path: polygon(0 0, 100% 0, 100% 100%, 2% 100%, 0% 50%, 0 0);
        }
        .navitems {
            display: flex;
            transform-origin: right;
        }
        .navitem {
            padding: 0px 1vw;
            font-size: 0.9vw;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
        }
        .navitem:after {
            content: "";
            display: block;
            background-color: #00ffff;
            clip-path: polygon(0 0, 10% 0, 100% 100%, 90% 100%);
            margin-left: 2vw;
            height: 2.2vw;
            width: 1.3vw;
        }
        .navbarkachoda {
            position: absolute;
            height: 2.4vw;
            width: 1.3vw;
            background-color: #00ffff;
            bottom: -1.25vw;
            left: -0.41vw;
            clip-path: polygon(31% 0, 100% 50%, 50% 100%, 0 50%);
        }
        .navitem:last-child:after {
            visibility: hidden;
            margin-left: 0.3vw;
        }
        .nav-2 {
            z-index: 21;
            filter: blur(13.699999809265137px);
        }
    </style>
</head>
<body>
    <img src="/overlay.png" class="overlayBg">
    <video muted loop>
        <source src="/bg.mp4" type="video/mp4">
    </video>
    <div class="dual-nav-container">
        <div class="navbar">
            <div class="navitems">
                <div class="navitem" style="padding-left: 1vw; position: relative;">
                    <span style="margin-left: 1.3vw;">LANDMARKS</span>
                    <div class="navbarkachoda"></div>
                </div>
                <div class="navitem">BUY</div>
                <div class="navitem">SOLUTION</div>
                <div class="navitem">CYBERPSYCHOSIS</div>
                <div class="navitem">LOGIN</div>
            </div>
        </div>
        <div class="navbar nav-2">
            <div class="navitems">
                <div class="navitem" style="padding-left: 1vw; position: relative;">
                    <span style="margin-left: 1.3vw;">LANDMARKS</span>
                    <div class="navbarkachoda"></div>
                </div>
                <div class="navitem">BUY</div>
                <div class="navitem">SOLUTION</div>
                <div class="navitem">CYBERPSYCHOSIS</div>
                <div class="navitem">LOGIN</div>
            </div>
        </div>
    </div>
    <script>
        window.onload = () => {
            document.getElementsByTagName('video')[0].play()
        }
    </script>
</body>
</html>